{
	"outDir": "src/styles/tws/colors",
    "data": {
        "schemes": {
            "modes": ["light", "dark"],
            "toggle": "attr"
        },
        "colors": {
            "base": "color",
            "map": {
                "neutral": {
                    "color": ["--neutral-50", "--indigo-950"],
                    "on-color": ["--neutral-950", "--neutral-100"],
                    "on-color-variant": ["--neutral-700", "--neutral-400"],
                    "outline": ["--neutral-600", "--indigo-500"],
                    "outline-variant": ["--neutral-300", "--indigo-800"],
                    "seed": ["--violet-600", "--violet-400"]
                },
                "primary": {
                    "color": ["--violet-950", "--violet-900"],
                    "on-color": ["--white", "--neutral-50"],
                    "on-color-variant": ["--violet-200", "--violet-200"],
                    "outline": ["--violet-300", "--violet-300"],
                    "outline-variant": ["--violet-700", "--violet-600"],
                    "gradient-stop-1": ["--violet-950", "--purple-800"],
                    "gradient-stop-2": ["--purple-800", "--violet-900"]
                },
                "accent": {
                    "color": ["--amber-500", "--amber-500"],
                    "on-color": ["--white", "--white"]
                }
            }
        },
        "default": "neutral"
    }
}